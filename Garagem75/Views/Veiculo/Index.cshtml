@using Garagem75.Shared.Dtos

@model IEnumerable<VeiculoDto>

@{
    ViewData["Title"] = "Lista de veiculos";
}

<h1>Lista de veiculos</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Criar novo</a>
</p>
<style>
    .busca-veiculos {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

        .busca-veiculos input {
            width: 220px;
            border-radius: 8px;
            padding: 8px 12px;
            transition: box-shadow 0.2s ease;
        }

            .busca-veiculos input:focus {
                outline: none;
                box-shadow: 0 0 5px rgba(0, 123, 255, 0.6);
            }

        .busca-veiculos button,
        .busca-veiculos a {
            border-radius: 8px;
            padding: 8px 16px;
            transition: background-color 0.2s ease, transform 0.1s ease;
        }

            .busca-veiculos button:hover,
            .busca-veiculos a:hover {
                transform: scale(1.03);
            }

    @@media (max-width: 576px) {
        .busca-veiculos

    {
        flex-direction: column;
        align-items: stretch;
    }

    .busca-veiculos input,
    .busca-veiculos button,
    .busca-veiculos a {
        width: 100%;
    }

    }
</style>

<form asp-action="Index" method="get" class="busca-veiculos">
    <input type="text" name="searchPlaca" value="@Context.Request.Query["searchPlaca"]"
           class="form-control" placeholder="Buscar por placa" />

    <input type="text" name="searchCliente" value="@Context.Request.Query["searchCliente"]"
           class="form-control" placeholder="Buscar por cliente" />

    <button type="submit" class="btn btn-primary">🔍 Buscar</button>
    <a asp-action="Index" class="btn btn-secondary">Limpar</a>
</form>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fabricante)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Modelo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ano)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Placa)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClienteNome)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Fabricante)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Modelo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ano)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Placa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cor)
            </td>
                <td>@(item.ClienteNome != null ? item.ClienteNome : "— sem proprietário —")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdVeiculo" class="btn btn-primary">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.IdVeiculo" class="btn btn-secondary">Detalhes</a> |
                <a asp-action="Delete" asp-route-id="@item.IdVeiculo" class="btn btn-danger">Deletar</a>
            </td>
        </tr>
}
    </tbody>
</table>
