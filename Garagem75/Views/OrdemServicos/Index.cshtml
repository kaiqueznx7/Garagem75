@model IEnumerable<Garagem75.Shared.Dtos.OrdemServicoDto>;

@{
    ViewData["Title"] = "Ordens de Serviço";
}

<h1>Ordens de serviços</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Nova Ordem de Serviço</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@Context.Request.Query["searchString"]"
               class="form-control" placeholder="Buscar por placa..." />
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a asp-action="Index" class="btn btn-secondary">Limpar</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.VeiculoModelo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataServico)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descricao)
            </th>
            <th>
                @* CORREÇÃO: Remove a referência direta a 'Pecas' no cabeçalho *@
                Peças Utilizadas
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaoDeObra)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ValorDesconto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataEntrega)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ValorTotal)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @* Usando as propriedades diretas do seu DTO *@
                    @($"{item.VeiculoModelo} - {item.PlacaVeiculo}")
                </td>
                <td>
                    @item.DataServico.ToString("dd/MM/yyyy")
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Descricao)
                </td>
                <td>
                    @* CORREÇÃO: Usando a lista 'Pecas' que está no seu DTO *@
                    @if (item.PecasAssociadas != null && item.PecasAssociadas.Any())
                    {
                        <ul>
                            @foreach (var peca in item.PecasAssociadas)
                            {
                                <li>
                                    @* Aqui assumi que seu OrdemServicoPecaDto tem Nome, Quantidade e Valor *@
                                    @($"{peca.NomePeca} (x{peca.Quantidade}) - R$ {peca.PrecoUnitario:N2}")
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">Nenhuma peça</span>
                    }
                </td>
                <td>
                    @item.MaoDeObra.ToString()
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ValorDesconto)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DataEntrega)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ValorTotal)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdOrdemServico" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.IdOrdemServico" class="btn btn-sm btn-info">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@item.IdOrdemServico" class="btn btn-sm btn-danger">Excluir</a>
                </td>
             
             
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>
<script src="~/js/site.js"></script>