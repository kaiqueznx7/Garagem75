@model Garagem75.Shared.Dtos.OrdemServicoDto

@{
    ViewData["Title"] = "Criar nova ordem de serviço";
}

<h1 class="brand-text">Nova Ordem de Serviço</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" id="formOS">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="card-app" style="background: #1a1a1a; padding: 20px;color: antiquewhite;     border-radius: 15px; border-left: 5px solid #FFD700;">
                <div class="form-group mb-3">
                    <label asp-for="Descricao" class="control-label">Descrição do Problema/Serviço</label>
                    <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Ex: Revisão geral e troca de óleo"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="VeiculoId" class="control-label">Veículo</label>
                            <select asp-for="VeiculoId" class="form-control" asp-items="ViewBag.VeiculoId">
                                <option value="">Selecione o veículo...</option>
                            </select>
                            <span asp-validation-for="VeiculoId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="DataEntrega" class="control-label">Previsão de Entrega</label>
                            <input asp-for="DataEntrega" type="datetime-local" class="form-control" />
                            <span asp-validation-for="DataEntrega" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Mão de Obra (R$)</label>
                            @* Usamos name="MaoDeObraTexto" para o C# não validar como número antes do JS limpar *@
                            <input type="text" class="form-control dinheiro" id="MaoDeObraInput" name="MaoDeObraTexto" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Valor Desconto (R$)</label>
                            <input type="text" class="form-control dinheiro" id="ValorDescontoInput" name="ValorDescontoTexto" />
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mt-4 brand-text">Peças Utilizadas</h4>
            <div class="card-app" style="background: #1a1a1a; padding: 15px; border-radius: 15px;">
                <table class="table table-dark table-hover">
                    <thead>
                        <tr>
                            <th>Peça</th>
                            <th>Preço Unit.</th>
                            <th style="width: 120px;">Qtd.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Pecas != null)
                        {
                            foreach (var peca in (List<Garagem75.Shared.Dtos.PecaDto>)ViewBag.Pecas)
                            {
                                <tr>
                                    <td>@peca.Nome <br /><small class="text-muted">@peca.Marca</small></td>
                                    <td>R$ @peca.Preco.ToString("N2")</td>
                                    <td>
                                        <input type="number"
                                               class="form-control form-control-sm peca-quantidade-input"
                                               data-peca-id="@peca.IdPeca"
                                               value="0"
                                               min="0" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="form-group mt-4 mb-5">
                <button type="submit" class="btn btn-primary btn-lg w-100">Criar Ordem de Serviço</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Voltar para a Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>

    <script>
        $(document).ready(function () {
        // Aplica a máscara nos campos de texto que criamos
        $('#MaoDeObraInput, #ValorDescontoInput').mask('#.##0,00', { reverse: true });

        $('form').on('submit', function () {
        // 1. Remove hiddens de peças antigos para não duplicar
        $('input[name="pecaIds"], input[name="quantidades"]').remove();

        // 2. Cria novos hiddens apenas para as peças com quantidade > 0
        $('.peca-quantidade-input').each(function () {
        var qtd = parseInt($(this).val());
        var id = $(this).data('peca-id');
        if (qtd > 0) {
        $('<input>').attr({ type: 'hidden', name: 'pecaIds', value: id }).appendTo('form');
        $('<input>').attr({ type: 'hidden', name: 'quantidades', value: qtd }).appendTo('form');
        }
        });

        // Não limpamos os campos de valor aqui!
        // O C# vai ler o "MaoDeObraTexto" direto da máscara.
        return true;
        });
        });
    </script>
}