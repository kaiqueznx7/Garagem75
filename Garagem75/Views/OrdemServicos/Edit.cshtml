@model Garagem75.Shared.Dtos.OrdemServicoDto

@{
    ViewData["Title"] = "Editar ordem de serviço";
}

<h1>Editar</h1>
<h4>Ordem de Serviço - @Model.VeiculoModelo (@Model.PlacaVeiculo)</h4>
<hr />
<div class="row">
    <div class="col-md-8">
        @* Aumentei para 8 para a tabela de peças ficar melhor *@
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdOrdemServico" />
            
            @* Campos de IDs necessários para o DTO *@
            <input type="hidden" asp-for="VeiculoId" />
            <input type="hidden" asp-for="ClienteId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Descricao" class="control-label">Descrição</label>
                        <input asp-for="Descricao" class="form-control" />
                        <span asp-validation-for="Descricao" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DataServico" class="control-label">Data do Serviço</label>
                        <input asp-for="DataServico" type="date" class="form-control" />
                        <span asp-validation-for="DataServico" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="MaoDeObra" class="control-label">Mão de Obra (R$)</label>
                        <input asp-for="MaoDeObra" type="text" id="MaoDeObra" class="form-control" />
                        <span asp-validation-for="MaoDeObra" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Status" class="control-label"></label>
                        <select asp-for="Status" class="form-control">
                            <option value="Aberto">Aberto</option>
                            <option value="Em Andamento">Em Andamento</option>
                            <option value="Finalizado">Finalizado</option>
                            <option value="Cancelado">Cancelado</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DataEntrega" class="control-label">Previsão de Entrega</label>
                        <input asp-for="DataEntrega" type="date" class="form-control" />
                        <span asp-validation-for="DataEntrega" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ValorDesconto" class="control-label">Desconto (R$)</label>
                        <input asp-for="ValorDesconto" type="text" id="ValorDesconto" class="form-control" />
                        <span asp-validation-for="ValorDesconto" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <h4 class="mt-4">Peças Utilizadas</h4>
            <div class="form-group">
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Peça</th>
                            <th>Preço Unitário</th>
                            <th style="width: 120px;">Quantidade</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            // Cria um dicionário para saber quais peças já estão na ordem
                            // Usamos PecaId como chave e Quantidade como valor
                            var pecasNoDto = Model.Pecas?.ToDictionary(p => p.PecaId, p => p.Quantidade)
                                            ?? new Dictionary<int, int>();
                        }

                        @foreach (var peca in (List<Garagem75.Shared.Dtos.PecaDto>)ViewBag.Pecas)
                        {
                            var qtdAtual = pecasNoDto.ContainsKey(peca.IdPeca) ? pecasNoDto[peca.IdPeca] : 0;

                            <tr>
                                <td>@peca.Nome</td>
                                <td>@peca.Preco.ToString("C2")</td>
                                <td>
                                    <input type="number"
                                           class="form-control form-control-sm peca-quantidade-input"
                                           data-peca-id="@peca.IdPeca"
                                           value="@qtdAtual"
                                           min="0" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary" id="btnSalvarMvc">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
        $('form').submit(function (e) {
        // Remove campos antigos para evitar duplicatas se clicar duas vezes
        $('input[name="pecaIds"]').remove();
        $('input[name="quantidades"]').remove();

        $('.peca-quantidade-input').each(function () {
        var qtd = parseInt($(this).val());
        var id = $(this).data('peca-id');

        // Só envia se a quantidade for maior que zero
        if (qtd > 0) {
        // Cria Hidden para o ID da Peça
        $('<input>').attr({
        type: 'hidden',
        name: 'pecaIds',
        value: id
        }).appendTo('form');

        // Cria Hidden para a Quantidade (em vez de renomear o input da tabela)
        $('<input>').attr({
        type: 'hidden',
        name: 'quantidades',
        value: qtd
        }).appendTo('form');
        }
        });

        console.log("Enviando peças..."); // Para você ver no F12 se o script rodou
        return true;
        });
        });
    </script>
}