<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GARAGEM 75</title>
    
    <link href="~/lib/bootstrap/dist/css/bootstrap-spacelab.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
            body {
                background-color: #ffffff;
                color: #111111;
                margin: 0;
                padding: 0;
            }
        
            .navbar-custom {
                background-color: #111111;
                border-bottom: 6px solid #ffc107;
                padding: 0.5rem 1rem;
                position: relative; /* Necessário para a logo flutuar */
                z-index: 1000;
            }

            /* LOGO AUMENTADA SEM ALTERAR O CONTAINER */
            .navbar-brand {
                position: relative;
                padding: 0;
                margin: 0;
            }

                .navbar-brand img {
                    max-height: 180px; /* Aumentei bastante aqui */
                    width: auto;
                    position: absolute; /* Faz a logo flutuar */
                    top: -50px; /* Ajusta a posição para cima */
                    left: 0;
                    z-index: 1001;
                    filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.3)); /* Dá profundidade */
                    transition: transform 0.3s ease;
                }

                    .navbar-brand img:hover {
                        transform: scale(1.1);
                    }

            .btn-voltar {
                color: #ffc107 !important;
                border-color: #ffc107 !important;
                font-weight: bold;
                text-transform: uppercase;
            }

            .main-content {
                padding-top: 60px; /* Espaço para a logo não cobrir o texto inicial */
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
        <div class="container" style="height: 60px;">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/img/logoFrajola01.png" alt="Garagem 75 Logo" />
            </a>

            <div class="ms-auto">
                <a class="btn btn-outline-warning btn-voltar" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Voltar ao Site
                </a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>