<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GARAGEM 75</title>
    
    <link href="~/lib/bootstrap/dist/css/bootstrap-spacelab.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        body { background-color: #ffffff;
            color: #111111;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        
        /* LOGO AUMENTADA SEM ALTERAR O CONTAINER */
            .navbar-brand {
                position: relative;
                padding: 0;
                margin: 0;
            }

                .navbar-brand img {
                    max-height: 180px; /* Aumentei bastante aqui */
                    width: auto;
                    position: absolute; /* Faz a logo flutuar */
                    top: -50px; /* Ajusta a posição para cima */
                    left: 0;
                    z-index: 1001;
                    filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.3)); /* Dá profundidade */
                    transition: transform 0.3s ease;
                }

                    .navbar-brand img:hover {
                        transform: scale(1.1);
                    }

            .btn-voltar {
                color: #ffc107 !important;
                border-color: #ffc107 !important;
                font-weight: bold;
                text-transform: uppercase;
            }

            .main-content {
                padding-top: 60px; /* Espaço para a logo não cobrir o texto inicial */
            }

        /* SIDEBAR (Menu Lateral) */
        .sidebar {
            background-color: #111111;
            min-height: calc(100vh - 66px); /* Altura total menos a navbar */
            color: white;
            padding-top: 50px; /* Espaço para a logo flutuante */
        }

        .sidebar a {
            color: #ffffff;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            border-bottom: 1px solid #333;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background-color: #ffc107;
            color: #111111;
        }

        .sidebar a i { margin-right: 10px; color: #ffc107; }
        .sidebar a:hover i { color: #111111; }

        .main-content { padding: 20px; }
        
        .btn-voltar {
            color: #ffc107 !important;
            border-color: #ffc107 !important;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
        <div class="container-fluid" style="height: 60px;">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/img/logoFrajola01.png" alt="Garagem 75 Logo" />
            </a>

            <div class="ms-auto">
                <a class="btn btn-outline-warning btn-voltar" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Voltar ao Site
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky">
                    <a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
                    <a asp-controller="OrdemServicos" asp-action="Index"><i class="bi bi-file-earmark-text"></i> Ordens de Serviço</a>
                    <a asp-controller="Veiculo" asp-action="Index"><i class="bi bi-car-front"></i> Veículos</a>
                    <a asp-controller="Cliente" asp-action="Index"><i class="bi bi-person-badge"></i> Clientes</a>
                    <a asp-controller="Peca" asp-action="Index"><i class="bi bi-tools"></i> Estoque de Peças</a>
                    <a asp-controller="Usuario" asp-action="Index"><i class="bi bi-people"></i> Usuários</a>
                    <hr style="border-color: #333;" />
                    <form asp-controller="Usuario" asp-action="Logout" method="post" id="logoutForm" class="d-none">
                    @Html.AntiForgeryToken()
                    </form>

<a href="javascript:document.getElementById('logoutForm').submit();" class="text-danger">
    <i class="bi bi-box-arrow-right"></i> Sair do Sistema
</a>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>